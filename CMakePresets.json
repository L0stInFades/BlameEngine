{
  "version": 2,
  "configurePresets": [
    {
      "name": "terminal-dev",
      "displayName": "Terminal / HackOps development",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/out/build/terminal-dev",
      "cacheVariables": {
        "BUILD_TOOLS": "ON",
        "BUILD_GAME_HACKOPS": "ON",
        "BUILD_TESTS": "OFF",
        "BUILD_TERMINAL": "ON"
      }
    },
    {
      "name": "headless",
      "displayName": "Headless authoritative-world core (no renderer, no game)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/out/build/headless",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_TOOLS": "ON",
        "BUILD_GAME_HACKOPS": "OFF",
        "BUILD_TESTS": "ON",
        "BUILD_TERMINAL": "OFF"
      }
    },
    {
      "name": "windows-headless",
      "displayName": "Windows headless core (MSVC + Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/windows-headless",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_TOOLS": "ON",
        "BUILD_GAME_HACKOPS": "OFF",
        "BUILD_TESTS": "ON",
        "BUILD_TERMINAL": "OFF"
      }
    },
    {
      "name": "asan",
      "displayName": "ASan + UBSan test build (macOS/Linux)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/out/build/asan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NEXT_SANITIZE": "address,undefined",
        "BUILD_TESTS": "ON",
        "BUILD_TOOLS": "ON",
        "BUILD_TERMINAL": "OFF",
        "BUILD_GAME_HACKOPS": "OFF"
      }
    },
    {
      "name": "tsan",
      "displayName": "ThreadSanitizer test build (lock-free boundary primitives)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/out/build/tsan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "NEXT_SANITIZE": "thread",
        "BUILD_TESTS": "ON",
        "BUILD_TOOLS": "OFF",
        "BUILD_TERMINAL": "OFF",
        "BUILD_GAME_HACKOPS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "terminal-dev",
      "configurePreset": "terminal-dev",
      "targets": [
        "next_compression_probe",
        "next_nvim_surface_probe",
        "hackops_demo"
      ]
    },
    {
      "name": "headless",
      "configurePreset": "headless"
    },
    {
      "name": "windows-headless",
      "configurePreset": "windows-headless"
    },
    {
      "name": "asan",
      "configurePreset": "asan"
    },
    {
      "name": "tsan",
      "configurePreset": "tsan"
    }
  ]
}
